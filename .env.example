APP_NAME="Igreja em Charqueadas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Em produção, defina o domínio real (usado em canonical, sitemap, og:url e JSON-LD)
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção (HTTPS), defina como true para o cookie de sessão só trafegar via HTTPS.
SESSION_SECURE_COOKIE=false

# API mobile (Sanctum)
# Expiração do token em minutos. Vazio = não expira. Ex.: 43200 = 30 dias.
SANCTUM_TOKEN_EXPIRATION=
# Origens permitidas no CORS da API, separadas por vírgula. Vazio/ausente libera tudo (só dev).
# Em produção: CORS_ALLOWED_ORIGINS=https://app.suaigreja.com,https://suaigreja.com
CORS_ALLOWED_ORIGINS=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# reCAPTCHA v3 — chaves em https://www.google.com/recaptcha/admin (tipo: reCAPTCHA v3)
RECAPTCHA_SITEKEY=
RECAPTCHA_SECRET=
# Nota mínima (0.0–1.0) para aceitar o envio. Padrão 0.5.
RECAPTCHA_SCORE_THRESHOLD=0.5

# Push notifications (Firebase Cloud Messaging)
FIREBASE_CREDENTIALS=
# FIREBASE_CREDENTIALS=storage/app/firebase/credentials.json (Service Account JSON path)
